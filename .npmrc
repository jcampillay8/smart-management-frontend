# ==============================================================================
# CONFIGURACIÓN DE SEGURIDAD BLINDADA - PNPM 11
# Proyecto: Frontend (React + Vite + TanStack)
# ==============================================================================

# 1. PROTECCIÓN CONTRA SUPPLY CHAIN ATTACKS (RECOMENDACIÓN MIDUDEV)
# ------------------------------------------------------------------------------
# No instala paquetes con menos de 24 horas (1440 min) de vida.
# Esto previene ataques relámpago como el de TanStack Query.
pnpm.minimum-release-age=1440

# 2. BLOQUEO DE SCRIPTS MALICIOSOS (EL "INTERRUPTOR DEL HOMBRE MUERTO")
# ------------------------------------------------------------------------------
# Desactiva la ejecución automática de scripts (preinstall, postinstall)
# de las dependencias. El malware no podrá ejecutarse al descargar.
never-built-dependencies=true
ignore-scripts=true

# 3. AISLAMIENTO Y ESTRUCTURA (ANTI-PHANTOM DEPENDENCIES)
# ------------------------------------------------------------------------------
# Evita que las dependencias accedan a otros paquetes no declarados.
hoist=false
shamefully-hoist=false

# 4. SEGURIDAD DE RED Y REGISTROS
# ------------------------------------------------------------------------------
# Bloquea dependencias que apunten a URLs externas no seguras (git, http).
block-exotic-dependencies=true

# Fuerza el uso de HTTPS para todo.
registry=https://registry.npmjs.org/
strict-ssl=true

# 5. INTEGRIDAD DE LA INSTALACIÓN
# ------------------------------------------------------------------------------
# Verifica que el contenido descargado coincida exactamente con el hash.
verify-store-integrity=true

# 6. OPTIMIZACIÓN DE RENDIMIENTO (OPCIONAL)
# ------------------------------------------------------------------------------
# Aprovecha el almacenamiento basado en contenido de pnpm.
package-import-method=auto